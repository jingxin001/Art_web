{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "artweb",
  "compatibility_date": "2026-04-15",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "fenghuaart.com",
      "custom_domain": true
    },
    {
      "pattern": "www.fenghuaart.com",
      "custom_domain": true
    }
  ],
  "build": {
    "command": "npm run build"
  }
}
